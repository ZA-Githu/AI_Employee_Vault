# ─────────────────────────────────────────────────────────────
# AI Employee Vault — Environment Configuration
# Bronze Tier | Personal AI Employee Hackathon 2026
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────


# ── Vault Paths ───────────────────────────────────────────────

# Absolute path to your Obsidian vault root.
# Use forward slashes even on Windows.
# Example (Windows): C:/Users/YourName/Documents/AI_Employee_Vault
# Example (Mac/Linux): /Users/yourname/AI_Employee_Vault
VAULT_PATH=.

# Folder names inside the vault (relative to VAULT_PATH).
# Change only if you renamed the default folders.
INBOX_FOLDER=Inbox
NEEDS_ACTION_FOLDER=Needs_Action
LOGS_FOLDER=Logs


# ── Watcher Behaviour ─────────────────────────────────────────

# Set to true to detect files without moving them.
# Useful for testing. Overridden by --dry-run CLI flag.
DRY_RUN=false

# Polling fallback interval in seconds (used if OS events are unavailable).
# Bronze Tier minimum: 60. Recommended: 60–300.
WATCH_INTERVAL=60


# ── Logging ───────────────────────────────────────────────────

# Console log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
